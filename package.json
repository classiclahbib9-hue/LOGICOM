{
    "name": "logicom-desktop",
    "version": "1.0.0",
    "description": "LOGICOM - Editeur Interactif",
    "main": "main.js",
    "scripts": {
        "start": "set ELECTRON_RUN_AS_NODE=&& electron .",
        "build": "electron-builder",
        "push-all": "git add . && git commit -m \"Update LOGICOM\" && git push origin main",
        "compile": "npm run build && npm run push-all"
    },
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "electron": "^29.1.0",
        "electron-builder": "^24.13.3"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.101.1",
        "dotenv": "^17.4.1",
        "node-telegram-bot-api": "^0.67.0",
        "qrcode-terminal": "^0.12.0",
        "sql.js": "^1.14.1",
        "whatsapp-web.js": "^1.34.6"
    },
    "build": {
        "appId": "com.logicom.desktop",
        "productName": "LOGICOM",
        "npmRebuild": false,
        "win": {
            "target": [
                "nsis",
                "zip",
                "portable"
            ]
        },
        "nsis": {
            "oneClick": true,
            "allowToChangeInstallationDirectory": false,
            "createDesktopShortcut": true
        }
    }
}
